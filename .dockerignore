# Version control
.git/
.gitignore

# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / coverage output
.pytest_cache/
.coverage
coverage.xml
htmlcov/
test-results.xml

# Environment files
.env
.env.*
*.local

# Logs
*.log

# CI / tooling config (not needed at runtime)
.github/
.gitlab-ci.yml
sonar-project.properties
.sonar/

# Docker files (no need to copy into the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# nginx / scripts (runtime deployment artefacts)
nginx/
scripts/

# Editors
.vscode/
.idea/
*.swp
*.swo

# Docs
README.md
answers.md
docs/

# uv lockfile (not used inside image)
uv.lock
